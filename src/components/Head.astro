---
import Default from '@astrojs/starlight/components/Head.astro';
import { ClientRouter } from 'astro:transitions';
---

<Default {...Astro.props}><slot /></Default>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=ZCOOL+KuaiLe&text=%E5%9C%A8%E8%BF%99%E9%87%8C%E5%BC%80%E5%A7%8B&display=swap" rel="stylesheet" />

<script is:inline type="text/javascript">
	(function(c,l,a,r,i,t,y){
		c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
		t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
		y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
	})(window, document, "clarity", "script", "xlxf8sqhve");
</script>

<script is:inline>
  function markActive() {
    var current = window.location.pathname.replace(/\/$/, '');
    document.querySelectorAll('#starlight__sidebar a[href]').forEach(function (a) {
      var href = (a.getAttribute('href') || '').replace(/\/$/, '');
      if (href === current) {
        a.setAttribute('aria-current', 'page');
      } else {
        a.removeAttribute('aria-current');
      }
    });
  }

  let savedSidebarScroll = 0;

  document.addEventListener('astro:before-swap', function () {
    var sidebar = document.querySelector('.sidebar-pane');
    if (sidebar) {
      savedSidebarScroll = sidebar.scrollTop;
    }
  });

  document.addEventListener('astro:after-swap', function () {
    markActive();
    var sidebar = document.querySelector('.sidebar-pane');
    if (sidebar) {
      sidebar.scrollTop = savedSidebarScroll;
    }
  });

  document.addEventListener('astro:page-load', function () {
    markActive();
    var sidebar = document.querySelector('.sidebar-pane');
    if (sidebar) {
      sidebar.scrollTop = savedSidebarScroll;
    }
  });

  markActive();
</script>

<script is:inline>
  (function () {
    function ensureBackdrop() {
      if (document.getElementById('sidebar-backdrop') || !document.body) return;
      var bd = document.createElement('div');
      bd.id = 'sidebar-backdrop';
      document.body.appendChild(bd);
      bd.addEventListener('click', function () {
        var toggle = document.querySelector('starlight-menu-button');
        if (toggle) { var btn = toggle.querySelector('button'); if (btn) btn.click(); }
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', ensureBackdrop);
    } else {
      ensureBackdrop();
    }
    document.addEventListener('astro:page-load', ensureBackdrop);
  })();
</script>

<script is:inline>
  (function () {
    var SITE_NAME = 'MSCPO开服文档';
    var CATEGORIES = [
      { prefix: '/java/', label: 'Java篇' },
      { prefix: '/bedrock/', label: '基岩篇' },
      { prefix: '/blog/', label: '番外篇' },
      { prefix: '/extra/', label: '番外篇' },
      { prefix: '/contribute/', label: '番外篇' },
      { prefix: '/progress/', label: '编写进度' },
    ];

    function formatTitle() {
      var path = window.location.pathname.replace(/index\.html$/, '');
      var category = '';
      for (var i = 0; i < CATEGORIES.length; i++) {
        if (path === CATEGORIES[i].prefix || path.indexOf(CATEGORIES[i].prefix) === 0) {
          category = CATEGORIES[i].label;
          break;
        }
      }
      var currentTitle = document.title;
      var sep = currentTitle.indexOf(' | ');
      var pageTitle = sep > -1 ? currentTitle.substring(0, sep) : currentTitle;
      if (!category) {
        document.title = pageTitle ? pageTitle + ' | ' + SITE_NAME : SITE_NAME;
      } else if (!pageTitle || pageTitle.trim() === '' || pageTitle === category) {
        document.title = category + ' | ' + SITE_NAME;
      } else {
        document.title = category + ' | ' + pageTitle + ' | ' + SITE_NAME;
      }
    }

    formatTitle();
    document.addEventListener('astro:after-swap', formatTitle);
  })();
</script>

<ClientRouter fallback="animate" />
