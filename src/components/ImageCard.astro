---
import { Icon } from '@astrojs/starlight/components';

interface Props {
  title: string;
  img: string;
  link: string;
  alt?: string;
}

const { title, img, link, alt = '' } = Astro.props;
---

<a href={link} class="card-link">
  <article class="sl-flex card">
    <p class="sl-flex title">
      <span class="icon">
        <img src={img} alt={alt} width="28" height="28" />
      </span>
      <span>{title}</span>
    </p>
    <span class="arrow-btn">
      <span class="arrow-text">前往</span>
      <Icon name="right-arrow" size="1.5rem" />
    </span>
  </article>
</a>

<style>
  @media (min-width: 50rem) {
    .card-link {
      display: flex;
      flex: 1;
      min-width: 0;
    }

    .card {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
      border-radius: 1rem;
      gap: 1.25rem;
      width: 100%;
      will-change: transform;
    }

    .card:hover,
    .card-link:focus-visible .card {
      transform: scale(1.04);
    }

    .title {
      font-size: 1.5rem;
      letter-spacing: 0.06em;
    }

    .icon {
      width: 4rem;
      height: 4rem;
      margin-bottom: 0.25rem;
    }

    .arrow-btn {
      width: 3rem;
      height: 3rem;
      margin-top: 0.25rem;
    }
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    overflow: visible;
  }

  .card {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1rem;
    padding: 1.35rem 1.35rem;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    transition: border-color 0.25s ease, background 0.3s ease, color 0.3s ease;
    background: rgba(10, 10, 20, 0.7);
    backdrop-filter: blur(12px);
  }

  :global([data-theme='light']) .card {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(16px);
  }

  .card:hover,
  .card-link:focus-visible .card {
    border-color: rgba(255, 255, 255, 0.35);
  }

  :global([data-theme='light']) .card:hover,
  :global([data-theme='light']) .card-link:focus-visible .card {
    border-color: rgba(255, 255, 255, 0.85);
  }

  .card-link:focus-visible {
    outline: none;
  }

  .card-link:focus-visible .card {
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 2px var(--sl-color-accent);
  }

  .title {
    align-items: center;
    gap: 0.65rem;
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.25;
    margin: 0;
    color: #fff;
    flex-shrink: 0;
    transition: color 0.3s ease;
  }

  :global([data-theme='light']) .title {
    color: #1a1a2e;
  }

  .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
  }

  .icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .arrow-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: var(--sl-color-accent);
    color: #fff;
    overflow: hidden;
    flex-shrink: 0;
    padding: 0;
    transition: background 0.3s ease;
  }

  .arrow-btn :global(svg) {
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  .arrow-text {
    display: none;
  }
</style>
